// ========== DASHBOARD ROUTES ==========

// Get dashboard statistics
app.get('/dashboard/stats', authenticateToken, (req, res) => {
  const today = new Date().toISOString().split('T')[0];
  const isEmployee = req.user.role === 'employee';

  if (isEmployee) {
    // Employee dashboard stats - use employee_id to find user id
    db.get(
      `SELECT id FROM users WHERE employee_id = ?`,
      [req.user.id],
      (err, userRecord) => {
        if (err || !userRecord) {
          return res.status(500).json({ message: 'Database error' });
        }
        const userId = userRecord.id;
        
        db.get(
          `SELECT 
            (SELECT COUNT(*) FROM attendance WHERE user_id = ? AND date >= date('now', '-30 days')) as days_present,
            (SELECT amount FROM salary WHERE user_id = ? AND status = 'Released' ORDER BY period_end DESC LIMIT 1) as latest_salary,
            (SELECT COUNT(*) FROM salary WHERE user_id = ? AND status = 'Pending') as pending_claims
          `,
          [userId, userId, userId],
          (err, stats) => {
            if (err) {
              return res.status(500).json({ message: 'Database error' });
            }
            res.json({ stats: stats || { days_present: 0, latest_salary: 0, pending_claims: 0 } });
          }
        );
      }
    );
  } else {
    // Admin/Manager dashboard stats
    db.get(
      `SELECT 
        (SELECT COUNT(*) FROM users WHERE status = 'active') as total_employees,
        (SELECT COUNT(*) FROM attendance WHERE date = ?) as today_present,
        (SELECT COUNT(*) FROM salary WHERE status = 'Pending') as pending_salaries,
        (SELECT SUM(amount) FROM salary WHERE status = 'Pending') as pending_amount,
        (SELECT COUNT(*) FROM attendance WHERE date >= date('now', '-7 days')) as week_attendance
      `,
      [today],
      (err, stats) => {
        if (err) {
          return res.status(500).json({ message: 'Database error' });
        }
        res.json({ stats: stats || { total_employees: 0, today_present: 0, pending_salaries: 0, pending_amount: 0, week_attendance: 0 } });
      }
    );
  }
});

// ========== PROFILE ROUTES ==========

// Upload profile photo
app.post('/users/upload-photo', authenticateToken, upload.single('photo'), async (req, res) => {
  if (!req.file) {
    return res.status(400).json({ message: 'No file uploaded' });
  }

  let imageUrl = null;

  if (supabase) {
    const fileName = `profiles/${req.user.id}_${Date.now()}.jpg`;
    const { data, error } = await supabase.storage
      .from(process.env.SUPABASE_BUCKET || 'profile-images')
      .upload(fileName, req.file.buffer, {
        contentType: req.file.mimetype,
        cacheControl: '3600'
      });

    if (!error) {
      imageUrl = supabase.storage
        .from(process.env.SUPABASE_BUCKET || 'profile-images')
        .getPublicUrl(fileName).data.publicUrl;
    }
  } else {
    // Fallback: save to local filesystem or return base64
    imageUrl = `data:${req.file.mimetype};base64,${req.file.buffer.toString('base64')}`;
  }

  // Get user ID first, then update profile
  db.get('SELECT id FROM users WHERE employee_id = ?', [req.user.id], (err, user) => {
    if (err || !user) {
      return res.status(404).json({ message: 'User not found' });
    }

    db.run(
      'UPDATE users SET profile_image_url = ? WHERE id = ?',
      [imageUrl, user.id],
      (err) => {
        if (err) {
          return res.status(500).json({ message: 'Failed to update profile' });
        }
        res.json({ success: true, imageUrl, message: 'Profile photo updated successfully' });
      }
    );
  });
});

